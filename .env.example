NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Keep this out of browser/client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Staff admin login (required for /staff pages).
STAFF_ADMIN_USERNAME=admin
STAFF_ADMIN_PASSWORD=choose-a-strong-password
STAFF_SESSION_SECRET=generate-a-long-random-string

# Stripe card payments (50% deposit at booking).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Staff email notifications. Resend is used via its HTTP API.
RESEND_API_KEY=your-resend-api-key
STAFF_NOTIFICATION_EMAIL=staff@example.com
# Optional fallback when no emails are saved in /staff/settings.
BOOKING_EMAIL_FROM=Kamala Guesthouse <bookings@your-domain.com>
# Default currency is set in /staff/settings (THB or USD).
# Optional inbound domain for email replies (e.g. inbound.your-domain.com).
# Only needed if you later enable Resend inbound + /api/resend/inbound.
# BOOKING_INBOUND_DOMAIN=inbound.your-domain.com
# RESEND_INBOUND_WEBHOOK_SECRET=whsec_your-inbound-webhook-secret
